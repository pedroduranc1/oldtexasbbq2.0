# ================================================
# OLD TEXAS BBQ CRM - PRODUCTION ENVIRONMENT
# ================================================
# Copiar este archivo a .env.production.local y configurar valores reales
# IMPORTANTE: Nunca commitear .env.production.local

# ================================================
# Firebase Configuration (PRODUCCION)
# ================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_production_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# No usar emuladores en produccion
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# ================================================
# App Configuration (PRODUCCION)
# ================================================
NEXT_PUBLIC_APP_URL=https://crm.oldtexasbbq.com
NEXT_PUBLIC_APP_NAME=Old Texas BBQ CRM
NODE_ENV=production

# ================================================
# Session Security (JWT) - OBLIGATORIO
# ================================================
# IMPORTANTE: Generar una clave segura de 32+ caracteres
# Comando: openssl rand -base64 32
SESSION_SECRET=your_super_secure_session_secret_min_32_chars

# ================================================
# Cloudinary Configuration (PRODUCCION)
# ================================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ================================================
# Clip Payment Gateway (PRODUCCION)
# ================================================
# Obtener credenciales de produccion desde el dashboard de Clip
# https://dashboard.clip.mx
CLIP_API_KEY=your_production_clip_api_key
CLIP_SECRET_KEY=your_production_clip_secret
CLIP_MERCHANT_ID=your_merchant_id
NEXT_PUBLIC_CLIP_PUBLIC_KEY=your_public_key
CLIP_WEBHOOK_SECRET=your_webhook_secret

# Modo de Clip (production para produccion)
NEXT_PUBLIC_CLIP_MODE=production

# ================================================
# Google Analytics (OPCIONAL)
# ================================================
# Obtener desde Google Analytics > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ================================================
# Sentry Error Tracking (OPCIONAL)
# ================================================
# Obtener desde Sentry > Settings > Projects > Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_org
SENTRY_PROJECT=old-texas-crm

# ================================================
# Security Headers
# ================================================
# Content Security Policy - Ajustar segun dominios usados
# NEXT_PUBLIC_CSP_DOMAINS=https://crm.oldtexasbbq.com,https://res.cloudinary.com

# ================================================
# Rate Limiting (OPCIONAL)
# ================================================
# Limite de requests por IP por minuto
RATE_LIMIT_MAX=100

# ================================================
# Development Pages Access - DESACTIVAR EN PRODUCCION
# ================================================
# Dejar vacio o eliminar para bloquear acceso a /dev/*
NEXT_PUBLIC_DEV_ACCESS_KEY=

# ================================================
# Checklist Pre-Deployment
# ================================================
# [ ] SESSION_SECRET generado con openssl
# [ ] Firebase configurado con proyecto de produccion
# [ ] Cloudinary configurado
# [ ] Clip en modo production con credenciales reales
# [ ] Google Analytics configurado (opcional)
# [ ] Sentry configurado (opcional)
# [ ] HTTPS habilitado en el servidor
# [ ] Dominio configurado correctamente
# [ ] DNS apuntando al servidor
# [ ] Backup automatico de Firestore habilitado
